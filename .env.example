# Praxon — pick at least one LLM provider, or run Ollama locally.

# --- LLM providers (free) ---

# Groq — fast Llama 3.3 70B. Free key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini 2.0 Flash. Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# Cerebras (very fast). Free key: https://cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# Together AI. Free Llama 3.3 70B Turbo. https://api.together.xyz
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free

# OpenRouter — aggregator, many free models. https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# NVIDIA NIM. Free at https://build.nvidia.com
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct

# HuggingFace Inference. https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HF_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Ollama (local — no key needed). Install from https://ollama.com
# Pull a model first:  ollama pull llama3.1:8b
OLLAMA_ENABLED=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b

# --- Web search providers (pick one for the web_search tool) ---
TAVILY_API_KEY=
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=

# --- Storage ---
# Override default ~/.praxon
# PRAXON_DATA_DIR=

# --- Browser tool ---
# Set to "0" to run Playwright in headed mode for debugging
PRAXON_BROWSER_HEADLESS=1

# --- Supabase (optional — multi-user mode) ---
# Set these to enable auth + per-user persistence.
# Without these, Praxon runs single-user local-first.
# Apply: supabase/migrations/0001_init.sql in Supabase SQL editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Runtime ---
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Praxon
